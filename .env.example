NODE_ENV=production
PORT=5000

# MongoDB connection. Use one of these names; DATABASE_URL is preferred.
DATABASE_URL=
MONGO_URI=

JWT_SECRET=

# Frontend origins allowed to call this backend.
# Examples: http://localhost:5173,<frontend-origin>
CLIENT_URL=
CORS_ORIGINS=

# At least one AI provider key is required.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

PUBLIC_STORE_ID=
ADMIN_EMAIL=admin@demo.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Demo Admin
AI_LOCAL_URL=
DB_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT_MS=10000
